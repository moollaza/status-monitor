{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nazar",
  "main": "workers/site.js",
  "compatibility_date": "2026-04-26",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "website",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
